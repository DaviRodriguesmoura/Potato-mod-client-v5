                    nearestEnemy = enemiesNear.sort((a, b) => UTILS.getDistance(myPlayer.x2, myPlayer.y2, a.x2, a.y2) - UTILS.getDistance(myPlayer.x2, myPlayer.y2, b.x2, b.y2))[0];

