            function getGridObjects(pathMode, MAX_DIST, destination) {
                let gridObjects = visibleObjects.filter(obj =>
                    UTILS.getDistance(obj.x, obj.y, destination.x, destination.y) < MAX_DIST &&
                    obj.id != 15
                );

