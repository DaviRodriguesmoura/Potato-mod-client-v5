                    const pixelY = path[i].y - yOffset;

                    if (i === 0) {
                        mainContext.moveTo(pixelX, pixelY);
                    } else {
                        mainContext.lineTo(pixelX, pixelY);
                    }
                }

                mainContext.stroke();
                mainContext.restore();
