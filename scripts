// ============================================================
//  MENU MIKU v2 — onglets + Échap toggle + mode réduit
// ============================================================
(function initMikuMenu() {

    // ── Visual mod state ─────────────────────────────────────────────────────
    const THEMES = {
        none:     { color: null },
        night:    { color: 'rgba(10,15,40,0.55)'   },
        pinkDark: { color: 'rgba(80,5,40,0.58)'    },
        blueDark: { color: 'rgba(5,15,80,0.58)'    },
        pink:     { color: 'rgba(200,50,120,0.30)' },
        blue:     { color: 'rgba(30,80,200,0.30)'  },
    };
    const vis = { theme: 'night', shadows: true, hideGrid: true };

    // États menu
    let menuVisible  = true;   // false = tout caché (Échap)
    let menuReduced  = false;  // true  = mode gif only
    let activeTab    = 'gameplay';

    // ── Canvas patching ───────────────────────────────────────────────────────
    const SHADOW = { color:'rgba(0,0,0,0.72)', blur:20, ox:16, oy:16 };
    const BG = new Set(['#b9dda1','#a4d183','#8ab368','#c8e6a0','#7ec850']);
    let gameCanvas = null;
    const getGC  = () => gameCanvas || (gameCanvas = document.getElementById('gameCanvas'));
    const isGC   = (ctx) => { const gc=getGC(); return gc && ctx.canvas===gc; };
    let depth = 0;
    const _save = CanvasRenderingContext2D.prototype.save;
    const _rest = CanvasRenderingContext2D.prototype.restore;
    CanvasRenderingContext2D.prototype.save    = function(){ if(isGC(this)) depth++; _save.call(this); };
    CanvasRenderingContext2D.prototype.restore = function(){ if(isGC(this)&&depth>0) depth--; _rest.call(this); };
    const inWorld = (ctx) => isGC(ctx) && depth > 0;
    const applyS  = (ctx) => { ctx.shadowColor=SHADOW.color; ctx.shadowBlur=SHADOW.blur; ctx.shadowOffsetX=SHADOW.ox; ctx.shadowOffsetY=SHADOW.oy; };
    const clearS  = (ctx) => { ctx.shadowColor='transparent'; ctx.shadowBlur=0; ctx.shadowOffsetX=0; ctx.shadowOffsetY=0; };
    const _stroke = CanvasRenderingContext2D.prototype.stroke;
    CanvasRenderingContext2D.prototype.stroke = function(...a){ if(vis.hideGrid&&isGC(this)&&this.globalAlpha<0.2)return; _stroke.apply(this,a); };
    const _fill = CanvasRenderingContext2D.prototype.fill;
    CanvasRenderingContext2D.prototype.fill = function(...a){ const ok=vis.shadows&&inWorld(this)&&!BG.has(this.fillStyle); if(ok)applyS(this); _fill.apply(this,a); if(ok)clearS(this); };
    const _di = CanvasRenderingContext2D.prototype.drawImage;
    CanvasRenderingContext2D.prototype.drawImage = function(...a){ const img=a[0],huge=img&&img.width>=512&&img.height>=512; const ok=vis.shadows&&inWorld(this)&&!huge; if(ok)applyS(this); _di.apply(this,a); if(ok)clearS(this); };

    // ── Overlay canvas (thème) ────────────────────────────────────────────────
    let overlayCanvas = null;
    const createOverlay = () => {
        const gc = getGC(); if(!gc||overlayCanvas) return;
        overlayCanvas = document.createElement('canvas');
        overlayCanvas.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:5;';
        gc.parentNode.insertBefore(overlayCanvas, gc.nextSibling);
        const vig = document.createElement('div');
        vig.id = 'mikuVignette';
        vig.style.cssText = 'position:absolute;inset:0;box-shadow:inset 0 0 220px rgba(0,0,0,0.82);pointer-events:none;z-index:6;';
        gc.parentNode.appendChild(vig);
        if(getComputedStyle(gc.parentNode).position==='static') gc.parentNode.style.position='relative';
        (function loop(){
            const r=gc.getBoundingClientRect(),pr=gc.parentNode.getBoundingClientRect();
            overlayCanvas.width=gc.width; overlayCanvas.height=gc.height;
            overlayCanvas.style.left=(r.left-pr.left)+'px'; overlayCanvas.style.top=(r.top-pr.top)+'px';
            overlayCanvas.style.width=r.width+'px'; overlayCanvas.style.height=r.height+'px';
            const ctx2=overlayCanvas.getContext('2d');
            ctx2.clearRect(0,0,overlayCanvas.width,overlayCanvas.height);
            const col=THEMES[vis.theme]?.color;
            if(col){ctx2.globalCompositeOperation='source-over';ctx2.fillStyle=col;ctx2.fillRect(0,0,overlayCanvas.width,overlayCanvas.height);}
            requestAnimationFrame(loop);
        })();
    };
    const waitGC = setInterval(()=>{ if(document.getElementById('gameCanvas')){clearInterval(waitGC);createOverlay();} },150);

    // ── CSS ───────────────────────────────────────────────────────────────────
    const style = document.createElement('style');
    style.textContent = `
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Orbitron:wght@700;900&display=swap');

        #mikuWrap {
            position: absolute;
            left: 12px; top: 12px;
            width: 262px;
            font-family: 'Nunito', sans-serif;
            z-index: 9999;
            user-select: none;
        }

        /* ── MODE RÉDUIT : seulement le gif ── */
        #mikuWrap.reduced #mikuPanel { display: none; }
        #mikuWrap.reduced #mikuTabBar { display: none; }
        #mikuWrap.reduced #mikuBanner { border-radius: 14px; border-bottom: none; cursor: pointer; }
        #mikuWrap.reduced #mikuBannerBar { border-radius: 14px; }

        /* ── CACHÉ (Échap) ── */
        #mikuWrap.hidden { display: none; }

        /* ── Barre banner + boutons ── */
        #mikuBannerBar {
            position: relative;
            border-radius: 14px 14px 0 0;
            overflow: hidden;
            border: 1px solid rgba(57,220,205,0.30);
            border-bottom: none;
            background: #000;
            animation: mikuPulse 4s ease-in-out infinite;
        }
        #mikuWrap.reduced #mikuBannerBar {
            border: 1px solid rgba(57,220,205,0.30);
            border-radius: 14px;
            animation: mikuPulse 4s ease-in-out infinite;
        }
        @keyframes mikuPulse {
            0%,100%{ box-shadow: 0 0 20px rgba(57,220,205,0.10), 0 0 60px rgba(57,220,205,0.04); }
            50%    { box-shadow: 0 0 32px rgba(57,220,205,0.22), 0 0 90px rgba(57,220,205,0.09); }
        }

        #mikuBanner {
            width: 100%; height: 78px;
            object-fit: cover; object-position: center top;
            display: block;
            filter: brightness(0.88) saturate(1.3);
        }

        /* boutons sur la banner */
        .miku-banner-btn {
            position: absolute; top: 6px;
            width: 22px; height: 22px;
            background: rgba(0,20,18,0.75);
            border: 1px solid rgba(57,220,205,0.35);
            border-radius: 6px;
            color: #39dccd; font-size: 11px; font-weight: 900;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: background 0.15s, border-color 0.15s;
            line-height: 1;
        }
        .miku-banner-btn:hover { background: rgba(57,220,205,0.18); border-color: rgba(57,220,205,0.7); }
        #btnReduce { right: 34px; font-size: 14px; }
        #btnClose  { right: 8px;  font-size: 13px; }

        /* ── Onglets ── */
        #mikuTabBar {
            display: flex;
            background: rgba(0,10,12,0.98);
            border-left: 1px solid rgba(57,220,205,0.20);
            border-right: 1px solid rgba(57,220,205,0.20);
        }
        .miku-tab {
            flex: 1; padding: 7px 4px;
            font-family: 'Orbitron', monospace;
            font-size: 8px; font-weight: 700;
            letter-spacing: 1px; text-transform: uppercase;
            color: rgba(57,220,205,0.35);
            background: transparent; border: none;
            border-bottom: 2px solid transparent;
            cursor: pointer; transition: all 0.15s;
            text-align: center;
        }
        .miku-tab:hover { color: rgba(57,220,205,0.7); background: rgba(57,220,205,0.04); }
        .miku-tab.active {
            color: #39dccd;
            border-bottom: 2px solid #39dccd;
            background: rgba(57,220,205,0.06);
            text-shadow: 0 0 8px rgba(57,220,205,0.6);
        }

        /* ── Panel principal ── */
        #mikuPanel {
            background: linear-gradient(160deg, rgba(0,18,22,0.98) 0%, rgba(0,8,14,0.99) 100%);
            border: 1px solid rgba(57,220,205,0.20);
            border-top: none;
            border-radius: 0 0 14px 14px;
            padding: 10px 13px 12px;
            max-height: 340px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: rgba(57,220,205,0.2) transparent;
        }
        #mikuPanel::-webkit-scrollbar { width: 3px; }
        #mikuPanel::-webkit-scrollbar-thumb { background: rgba(57,220,205,0.2); border-radius: 2px; }

        /* contenu onglet */
        .miku-tab-content { display: none; }
        .miku-tab-content.active { display: block; }

        /* section title */
        .miku-section {
            font-family: 'Orbitron', monospace;
            font-size: 8px; font-weight: 700;
            color: rgba(57,220,205,0.40);
            letter-spacing: 3px; text-transform: uppercase;
            margin: 10px 0 6px;
            padding-bottom: 3px;
            border-bottom: 1px solid rgba(57,220,205,0.08);
        }
        .miku-section:first-child { margin-top: 2px; }

        /* toggle row */
        .miku-toggle {
            display: flex; align-items: center; gap: 9px;
            padding: 4px 0; cursor: pointer; transition: filter 0.15s;
        }
        .miku-toggle:hover { filter: brightness(1.25); }
        .miku-toggle input[type="checkbox"] {
            appearance: none; -webkit-appearance: none;
            width: 30px; height: 15px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(57,220,205,0.22);
            border-radius: 8px; position: relative;
            cursor: pointer; transition: background 0.2s; flex-shrink: 0;
        }
        .miku-toggle input[type="checkbox"]:checked {
            background: rgba(57,220,205,0.16);
            border-color: rgba(57,220,205,0.70);
            box-shadow: 0 0 7px rgba(57,220,205,0.35);
        }
        .miku-toggle input[type="checkbox"]::after {
            content: ''; position: absolute;
            width: 11px; height: 11px;
            background: rgba(57,220,205,0.35);
            border-radius: 50%; top: 1px; left: 1px;
            transition: transform 0.2s, background 0.2s;
        }
        .miku-toggle input[type="checkbox"]:checked::after {
            transform: translateX(15px); background: #39dccd;
            box-shadow: 0 0 6px rgba(57,220,205,0.85);
        }
        .miku-label {
            font-size: 11px; font-weight: 700;
            color: rgba(200,245,245,0.80); line-height: 1.3;
        }
        .miku-label small {
            display: block; font-size: 9px; font-weight: 400;
            color: rgba(57,220,205,0.38); margin-top: 1px;
        }

        /* troll badge */
        .troll-badge {
            display: none; margin-left: auto;
            font-size: 8px; font-weight: 900; color: #ff4488;
            background: rgba(255,50,100,0.10);
            border: 1px solid rgba(255,50,100,0.38);
            border-radius: 4px; padding: 1px 5px; letter-spacing: 1px;
            animation: trollBlink 0.6s ease-in-out infinite;
        }
        @keyframes trollBlink { 0%,100%{opacity:1} 50%{opacity:0.2} }

        /* theme grid */
        .theme-grid {
            display: grid; grid-template-columns: repeat(3,1fr);
            gap: 5px; margin: 6px 0 2px;
        }
        .theme-btn {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(57,220,205,0.10);
            color: rgba(57,220,205,0.32);
            padding: 7px 3px; cursor: pointer;
            font-size: 10px; font-weight: 700;
            border-radius: 8px; line-height: 1.5;
            font-family: 'Nunito', sans-serif; transition: all 0.15s;
        }
