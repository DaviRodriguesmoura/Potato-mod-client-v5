                if (tmpText != "" && tmpObj.name != "Trash Slave") {
                    // bots.forEach((bot) => {
                    //     if (tmpObj.sid == bot.sid) return;
                    // });
                    mainContext.font = (tmpObj.nameScale || 30) + "px HammerSmith One";
