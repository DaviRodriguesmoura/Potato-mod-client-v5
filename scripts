            // Draw current path
            function drawPath(path) {
                if (!path || path.length < 2) return;

                mainContext.save();
                mainContext.strokeStyle = '#ffffffff';
                mainContext.lineWidth = 3;
                mainContext.beginPath();

                for (let i = 0; i < path.length; i++) {
